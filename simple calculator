<html>
<head>
<script>
function calc()
{
    var a = parseFloat(document.frm.n1.value);
    var b = parseFloat(document.frm.n2.value);
    var op = document.frm.choice.value;

    if(op == "+")
        document.frm.result.value = a + b;
    else if(op == "-")
        document.frm.result.value = a - b;
    else if(op == "*")
        document.frm.result.value = a * b;
    else if(op == "/")
        document.frm.result.value = a / b;
}
</script>
</head>

<body>

<form name="frm">

Enter Value 1:
<input type="text" name="n1"><br><br>

Enter Value 2:
<input type="text" name="n2"><br><br>

Operation:
<select name="choice">
    <option value="+">+</option>
    <option value="-">-</option>
    <option value="*">*</option>
    <option value="/">/</option>
</select>

<br><br>

<input type="button" value="Calculate" onclick="calc()">

<br><br>

Result:
<input type="text" name="result" readonly>

</form>

</body>
</html>
